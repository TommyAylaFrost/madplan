{
  "name": "madplan",
  "version": "0.2.0",
  "private": true,
  "description": "Delt madplan-app: ugeplan, lager med udløbsdato og indkøbsliste for familien",
  "scripts": {
    "dev": "wrangler pages dev public --compatibility-date=2026-07-01",
    "deploy": "wrangler pages deploy public --project-name=madplan",
    "db:create": "wrangler d1 create madplan-db",
    "db:migrate:local": "wrangler d1 execute madplan-db --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute madplan-db --remote --file=schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  }
}
